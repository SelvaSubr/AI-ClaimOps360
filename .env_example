# AI-ClaimOps360 Environment Variables
# Copy to .env and fill in real values
# Run: cp .env.example .env && chmod 600 .env

# ── Azure ─────────────────────────────────────────────────────────────────
# These are also used by Terraform via: make tf-plan / make tf-apply
# (Makefile maps AZURE_* → TF_VAR_* automatically — no secrets in tfvars)
AZURE_SUBSCRIPTION_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=<paste-here>
AZURE_KEY_VAULT_NAME=your-key-vault-name
AZURE_SERVICE_PRINCIPAL_OBJECT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_RESOURCE_GROUP=rg-name-001
AZURE_LOCATION=eastus2

# ── ADLS Gen2 ─────────────────────────────────────────────────────────────
ADLS_ACCOUNT_NAME=your-storage-account-name
ADLS_ACCOUNT_KEY=your-adls-key  # pragma: allowlist secret
ADLS_CONTAINER_BRONZE=bronze
ADLS_CONTAINER_SILVER=silver
ADLS_CONTAINER_GOLD=gold

# ── Databricks ────────────────────────────────────────────────────────────
DATABRICKS_HOST=https://your-workspace.azuredatabricks.net
DATABRICKS_TOKEN=dapi_your_token_here
DATABRICKS_CLUSTER_ID=your-cluster-id
DATABRICKS_EXPERIMENT_NAME=/your-workspace/denial-risk-model
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/your-warehouse-id
DATABRICKS_CATALOG=main

# ── Snowflake ─────────────────────────────────────────────────────────────
SNOWFLAKE_ACCOUNT=your-account.region
SNOWFLAKE_USER=your-snowflake-service-user
SNOWFLAKE_PASSWORD=<paste here>
SNOWFLAKE_ROLE=SYSADMIN
SNOWFLAKE_DATABASE=CLAIMS_ANALYTICS
SNOWFLAKE_WAREHOUSE=CLAIMS_WH
SNOWFLAKE_SCHEMA=PUBLIC

# ── Kafka ─────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9093
KAFKA_CONSUMER_GROUP=claims-bronze
KAFKA_PAYER_CONSUMER_GROUP=claims-payer
KAFKA_REMITTANCE_CONSUMER_GROUP=claims-remittance
KAFKA_ARCHIVE_CONSUMER_GROUP=claims-archive
KAFKA_TOPIC_CLAIMS_RAW=claims.raw
KAFKA_TOPIC_REMITTANCE=remittance.835
KAFKA_TOPIC_CLAIMS_VALIDATED=claims.validated
KAFKA_TOPIC_REVIEW_QUEUE=claims.review_queue
KAFKA_TOPIC_REJECTED=claims.rejected
KAFKA_MAX_MESSAGES=100
KAFKA_STREAMING_STARTING_OFFSETS=latest

# ── Delta Lake paths (local dev) ──────────────────────────────────────────
BRONZE_PATH=/your/local/path/bronze # pragma: allowlist secret
SILVER_PATH=/your/local/path/silver
GOLD_PATH=/your/local/path/gold
CHECKPOINT_DIR=/your/local/path/checkpoints
KAFKA_ARCHIVE_PATH=/your/local/path/archive

# Integration test runs — isolated data
BRONZE_PATH_INT=/your/local/path/integration/bronze
SILVER_PATH_INT=/your/local/path/integration/silver
GOLD_PATH_INT=/your/local/path/integration/gold
CHECKPOINT_DIR_INT=/your/local/path/integration/checkpoints

# ── Delta Lake paths (cloud — uncomment for Databricks) ──────────────────
# BRONZE_PATH=abfss://claims-data@youraccount.dfs.core.windows.net/bronze
# SILVER_PATH=abfss://claims-data@youraccount.dfs.core.windows.net/silver
# GOLD_PATH=abfss://claims-data@youraccount.dfs.core.windows.net/gold

# ── Enrollment ────────────────────────────────────────────────────────────
ENROLLMENT_834_PATH=sample_data/834/mock_enrollment_001.edi

# ── Risk tier thresholds ──────────────────────────────────────────────────
RISK_TIER_HIGH_USD=5000
RISK_TIER_MEDIUM_USD=1000

# ── Streaming inference thresholds ───────────────────────────────────────
REVIEW_SCORE_THRESHOLD=70
LOW_RISK_THRESHOLD=40

# ── Remittance ────────────────────────────────────────────────────────────
PAYER_ID=CLAIMOPS360
SUBMITTER_ID=CLAIMOPS360

# ── MLOps ─────────────────────────────────────────────────────────────────
FORCE_RETRAIN=false
MLFLOW_TRACKING_URI=databricks
MLFLOW_EXPERIMENT_NAME=/your-workspace/AI-ClaimOps360/denial-risk-model
MLFLOW_TRACKING_TOKEN=dapi_your_token_here
DENIAL_MODEL_VERSION=v2
# v1 = sklearn RF — use until make train-v2 has run
# v2 = LightGBM — set after make train-v2 registers V2 to MLflow Production

DATABRICKS_MODEL_ENDPOINT=
DATABRICKS_MODEL_ENDPOINT_ENABLED=false  # true=use REST endpoint, false=use local model file
IS_DUPLICATE_DEFAULT=0

# ── Snowflake Cortex ──────────────────────────────────────────────────────
CORTEX_MODEL=llama3.1-70b

# ── Microsoft Purview ─────────────────────────────────────────────────────
PURVIEW_ACCOUNT_NAME=your-purview-account-name
