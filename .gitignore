# AI-ClaimOps360 — .gitignore

# ── Python virtual environment ────────────────────────────────────────
.venv/
venv/
env/

# ── Python cache / compiled files ────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.so
.python-version

# ── Python build / packaging ──────────────────────────────────────────
build/
dist/
*.egg-info/
.eggs/
pip-log.txt

# ── Test / coverage ───────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.mypy_cache/
.ruff_cache/

# ── ML model artifacts ────────────────────────────────────────────────
# These are generated by make train / make train-v2 — never commit
src/ai_validation/models/*.pkl
src/ai_validation/models/*.json
src/ai_validation/models/*.bin
mlruns/
mlflow.db
mlruns.db

# ── Sensitive configs / secrets ───────────────────────────────────────
.env
.env.local
.env.*.local
.env.bak
.env.tmp

# ── Local CLI configs (contain tokens) ───────────────────────────────
.databrickscfg
.snowsql/
*.pem
*.key
*.p12
*_rsa
snowflake_credentials.json
.config

# ── Terraform ─────────────────────────────────────────────────────────
.terraform/
*.tfstate
*.tfstate.backup
terraform.tfvars
infra/terraform.tfvars
infra/*.tfvars
*.tfvars
*.tfvars.json
tfplan
*.tfplan
*.tfplan.json
infra/crash.log
crash.*.log

# ── Spark / Delta Lake (local dev) ────────────────────────────────────
/tmp/delta/
derby.log
metastore_db/
spark-warehouse/

# ── dbt ───────────────────────────────────────────────────────────────
dbt/target/
dbt/logs/
dbt/.user.yml
dbt/dbt_packages/

# ── Great Expectations uncommitted ────────────────────────────────────
data_quality/uncommitted/

# ── Sample data (PHI — never commit actual EDI or FHIR files) ───
sample_data/real/
*.edi.real

# ── Security scanning baseline ────────────────────────────────────────
.secrets.baseline

# ── Local tool configs ────────────────────────────────────────────────
.local/
azure-agent/

# ── IDE / editor settings ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Logs / temp files ─────────────────────────────────────────────────
*.log
logs/
tmp/
*.bak
*.orig
*.rej
*.bkp

# ── Mac OS / system files ─────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
.Trashes
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# ── Simulation config (mock-only, never commit) ──────────────────────────
src/simulation.config

# ── Message archive output ───────────────────────────────────────────────
archive/
log4j.properties
